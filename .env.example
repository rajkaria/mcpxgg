# =====================================================================
# MCPX — environment variables
# =====================================================================
# Copy to .env.local and fill in real values for local development.
# Never commit .env.local. CI/Vercel reads these from project settings.

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_FACILITATOR_URL=http://localhost:3002
NEXT_PUBLIC_INDEXER_URL=http://localhost:3003
NEXT_PUBLIC_DOCS_URL=http://localhost:3004

# ---------- Sui ----------
SUI_NETWORK=testnet                              # testnet | mainnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0x0                               # Move package address (set after first deploy)
SUI_REGISTRY_OBJECT_ID=0x0                       # NamespaceRegistry shared object
SUI_TREASURY_OBJECT_ID=0x0                       # PlatformTreasury shared object
SUI_INSURANCE_VAULT_OBJECT_ID=0x0                # InsurancePool shared object
SUI_PLATFORM_CONFIG_OBJECT_ID=0x0                # PlatformConfig shared object (take rate, etc.)
SUI_ADMIN_CAP_ID=0x0                             # Admin multisig cap

# Facilitator gas-station signer (sponsored gas)
FACILITATOR_SUI_PRIVATE_KEY=                     # Bech32 sui private key, server-only
FACILITATOR_TAKE_RATE_BPS=250                    # 2.5% in basis points (configurable on-chain)
FACILITATOR_INSURANCE_BPS=50                     # 0.5% diverted to insurance pool

# USDsui type tag
USDSUI_COIN_TYPE=0x...::usdsui::USDSUI

# ---------- Walrus ----------
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_RETENTION=permanent                       # all receipts permanent per DECISIONS.md

# ---------- Seal ----------
SEAL_PUBLIC_KEY=
SEAL_PRIVATE_KEY=                                # server-only

# ---------- Privy (wallet + social login) ----------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=                                # server-only

# ---------- Supabase (indexer mirror DB) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                       # server-only

# ---------- Upstash Redis (gateway auth cache + indexer pub/sub) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Twilio (sybil resistance for bootstrap subsidy) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---------- Bootstrap subsidy ----------
BOOTSTRAP_SUBSIDY_ATOMIC=1000000                 # 1.00 USDsui (6 decimals) per phone-verified new user
BOOTSTRAP_SUBSIDY_MONTHLY_BUDGET_ATOMIC=500000000 # cap total subsidy outflow per month

# ---------- Indexer ----------
INDEXER_START_CHECKPOINT=0
INDEXER_REORG_DEPTH=20

# ---------- Cron / scheduled jobs ----------
GATEWAY_CRON_SECRET=

# ---------- MCP Protocol ----------
MCP_PROTOCOL_VERSION=2025-03-26
