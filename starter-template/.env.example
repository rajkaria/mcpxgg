# ---------------------------------------------------------------------------
# MCPX MCP Server - Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# These variables are available inside tool execute() functions via
# process.env.VARIABLE_NAME.
# ---------------------------------------------------------------------------

# Server port for local development (default: 3000)
PORT=3000

# Add your API keys and secrets below.
# Example:
# OPENAI_API_KEY=sk-...
# MY_SERVICE_API_KEY=abc123
# DATABASE_URL=postgresql://user:pass@host:5432/db
