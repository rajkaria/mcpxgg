{
  "namespace": "my-server",
  "name": "My MCP Server",
  "description": "A starter MCP server built with MCPX.",
  "category": "other",
  "tags": [
    "starter",
    "example"
  ],
  "triggerPhrases": [
    "use my server"
  ],
  "endpointUrl": "https://my-server.netlify.app/mcp",
  "tools": [
    {
      "name": "echo",
      "description": "Echo a message back. Useful for testing connectivity.",
      "creditCost": 1,
      "timeoutSeconds": 5,
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "The message to echo back"
          }
        },
        "required": [
          "message"
        ]
      }
    },
    {
      "name": "random_number",
      "description": "Generate a random number between min and max (inclusive).",
      "creditCost": 1,
      "timeoutSeconds": 5,
      "inputSchema": {
        "type": "object",
        "properties": {
          "min": {
            "type": "number",
            "description": "Minimum value (inclusive)"
          },
          "max": {
            "type": "number",
            "description": "Maximum value (inclusive)"
          }
        },
        "required": [
          "min",
          "max"
        ]
      }
    }
  ]
}
